VITE_PINATA_JWT=your_pinata_jwt_token_here
# Public URL of the backend — set to your ngrok/deployed URL so Pera Wallet
# can fetch NFT images and metadata from outside localhost
VITE_SERVER_URL=http://localhost:3001
SERVER_PUBLIC_URL=http://localhost:3001
# Algorand mnemonic for the marketplace clawback wallet (25 words).
# If not set, a temporary wallet is generated on each server start — set this in production.
SERVER_WALLET_MNEMONIC=word1 word2 ... word25
